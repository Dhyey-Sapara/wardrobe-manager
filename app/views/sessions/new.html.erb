<div class="py-16">
  <div class="w-full mx-auto" style="max-width: 24rem">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-indigo-100 mb-4">
        <svg width="24" height="24" fill="none" stroke="#4f46e5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">Welcome back</h1>
      <p class="mt-1 text-sm text-gray-500">Log in to your wardrobe</p>
    </div>

    <div class="bg-white shadow-md rounded-2xl px-8 py-8 border border-gray-100">
      <% if alert %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-5 text-red-700 text-sm">
          <%= alert %>
        </div>
      <% end %>

      <%= form_with url: login_path, class: "space-y-4", data: { turbo: "false" } do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, required: true, autofocus: true, placeholder: "you@example.com",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, required: true, placeholder: "••••••••",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" %>
        </div>

        <%= f.submit "Log in",
            class: "w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 active:bg-indigo-800 transition-colors cursor-pointer mt-1" %>
      <% end %>

      <p class="mt-5 text-center text-sm text-gray-500">
        No account yet?
        <%= link_to "Sign up for free", signup_path, class: "text-indigo-600 hover:text-indigo-500 font-semibold" %>
      </p>
    </div>
  </div>
</div>
