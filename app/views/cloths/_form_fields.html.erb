<div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
  <!-- Type (enum) -->
  <div>
    <%= form.label :cloth_type, class: "block text-sm font-medium text-gray-700" %>
    <%= form.select :cloth_type,
        Cloth.cloth_types.keys.map { |t| [t.humanize, t] },
        { include_blank: "Select type" },
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <!-- Color -->
  <div>
    <%= form.label :color, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :color,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <!-- Location (user's locations) -->
  <div>
    <%= form.label :location_id, "Location", class: "block text-sm font-medium text-gray-700" %>
    <%= form.collection_select :location_id, @locations, :id, :name,
        { include_blank: "Select location" },
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-500">
      <%= link_to "Manage locations", locations_path, class: "text-indigo-600 hover:underline" %>
    </p>
  </div>

  <!-- Company -->
  <div>
    <%= form.label :company, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :company,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>
</div>
